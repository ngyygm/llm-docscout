{
  "_README": "Single source of truth for DocScout datasets. Each entry records how to reproduce the file (generator + args + seed), its split role, size, and lifecycle status. See DATA_PLAN.md §2.2. Regenerate any synth file with the listed command. NOTE: synth files currently embed full corpus per instance (huge); DATA_PLAN §3 migrates them to shared-corpus ref storage.",
  "_schema": {
    "id": "stable dataset id",
    "path": "file path (synth files are gitignored; reproduce via command)",
    "kind": "synth | grounded | persona",
    "generator": "module that produced it (synth only)",
    "command": "exact command to reproduce",
    "seed": "rng seed",
    "n_instances": "number of QA instances",
    "n_docs": "documents per corpus",
    "section_words_mean": "mean section length in WORDS (whitespace split, not BPE)",
    "split": "train | dev | eval | n/a",
    "role": "main | smoke | regression | diagnostic | real-eval",
    "status": "active | archived",
    "notes": "free text"
  },
  "datasets": [
    {
      "id": "synth_v3_singlehop_hard",
      "path": "data/synth/v3_eval300.json",
      "kind": "synth",
      "generator": "docscout.data.synth_v3_generator",
      "command": "python -m docscout.data.synth_v3_generator --n-instances 300 --seed 77 --out data/synth/v3_eval300.json",
      "seed": 77,
      "n_instances": 300,
      "n_docs": 24,
      "sections_per_doc": 10,
      "section_words_mean": 129,
      "kinds": {"single_hop": 200, "multi_hop": 100},
      "split": "eval",
      "role": "diagnostic",
      "status": "active",
      "notes": "Single-hop READ-required: answer not in snippet, must commit read. Healthy section length (~129 words). Used by diagnostic_snippet_only."
    },
    {
      "id": "synth_v4_chain_train",
      "path": "data/synth/v4_train1k.json",
      "kind": "synth",
      "generator": "docscout.data.synth_v4_generator",
      "command": "python -m docscout.data.synth_v4_generator --n-instances 1000 --seed 13 --out data/synth/v4_train1k.json",
      "seed": 13,
      "n_instances": 1000,
      "n_docs": 30,
      "section_words_mean": 25,
      "kinds": {"chain_2hop": 281, "chain_3hop": 413, "chain_4hop": 218, "chain_5hop": 88},
      "split": "train",
      "role": "main",
      "status": "active",
      "notes": "Numeric-equality chain (2-5 hop). MECHANISM-VALIDATION ONLY (review §4: 'numeric leapfrog' risk). Toy scale: 25-word sections -> no read-budget leverage (round-result.md). Superseded as main substrate by synth_v6_hetero once scaled."
    },
    {
      "id": "synth_v4_chain_dev",
      "path": "data/synth/v4_dev300.json",
      "kind": "synth",
      "generator": "docscout.data.synth_v4_generator",
      "command": "python -m docscout.data.synth_v4_generator --n-instances 300 --seed 41 --out data/synth/v4_dev300.json",
      "seed": 41,
      "n_instances": 300,
      "n_docs": 30,
      "section_words_mean": 25,
      "split": "dev",
      "role": "main",
      "status": "active",
      "notes": "v4 dev split (different seed from train/eval). Same generator distribution."
    },
    {
      "id": "synth_v4_chain_eval",
      "path": "data/synth/v4_eval300.json",
      "kind": "synth",
      "generator": "docscout.data.synth_v4_generator",
      "command": "python -m docscout.data.synth_v4_generator --n-instances 300 --seed 77 --out data/synth/v4_eval300.json",
      "seed": 77,
      "n_instances": 300,
      "n_docs": 30,
      "section_words_mean": 25,
      "kinds": {"chain_2hop": 99, "chain_3hop": 108, "chain_4hop": 57, "chain_5hop": 36},
      "split": "eval",
      "role": "main",
      "status": "active",
      "notes": "v4 eval. Referenced by diagnostic_closed_book / oracle_path / snippet_only / template_holdout."
    },
    {
      "id": "synth_v5_version_conflict",
      "path": "data/synth/v5_eval300.json",
      "kind": "synth",
      "generator": "docscout.data.synth_v5_generator",
      "command": "python -m docscout.data.synth_v5_generator --n-instances 300 --seed 77 --out data/synth/v5_eval300.json",
      "seed": 77,
      "n_instances": 300,
      "n_docs": 42,
      "section_words_mean": 28,
      "kinds": {"single": 245, "version_conflict": 55},
      "split": "eval",
      "role": "diagnostic",
      "status": "active",
      "notes": "Anti-cheat: current vs deprecated doc; ~20% version-conflict questions where deprecated value surfaces as snippet distractor. Tests read-past-snippet. Toy scale (~28 words)."
